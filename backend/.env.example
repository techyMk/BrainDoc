GROQ_API_KEY=gsk_...
VOYAGE_API_KEY=pa-...

# Shared secret. Frontend Next.js routes must send X-API-Key:<this>.
# Generate any random string >= 32 chars (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`)
# Leave blank to disable (NOT recommended in production).
APP_API_KEY=

# Model tuning (optional)
GROQ_MODEL=llama-3.3-70b-versatile
VOYAGE_EMBED_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2-lite

# Storage (per-user partitioning under USER_DATA_PATH/<user_id>/)
SEED_DOCS_PATH=./data/seed_docs
USER_DATA_PATH=./data/users

# Server
HOST=0.0.0.0
PORT=8001
ALLOWED_ORIGIN=http://localhost:3000
