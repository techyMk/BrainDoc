# Clerk auth — get from https://dashboard.clerk.com (free tier)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Required: route Clerk to the local pages (otherwise it uses Clerk's
# hosted Account Portal at *.accounts.dev, which isn't styled like BrainDoc).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Where the FastAPI backend lives. Server-side only — not exposed to the browser.
BACKEND_URL=http://127.0.0.1:8001

# Shared secret with the backend. MUST match APP_API_KEY in backend/.env.
# Server-side only — never prefix with NEXT_PUBLIC_.
APP_API_KEY=
